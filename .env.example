# Google Calendar - Service Account
# Google Cloud Console でサービスアカウントのJSONキーを作成し、
# ファイルの内容をそのまま（改行含む）1つの値として貼り付けてください
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"calendar-bot@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Google Calendar ID
# 個人カレンダー: Googleカレンダー → 設定 → 対象カレンダー → 「カレンダーの統合」からコピー
# 例: yourname@gmail.com  または  xxxxxxxxxx@group.calendar.google.com
CALENDAR_ID=your-email@gmail.com

# LINE Messaging API
# LINE Developers Console からコピー
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# グループに通知する場合はグループIDを設定（設定するとグループ優先、未設定なら Broadcast）
# webhook.py を Render 等にデプロイしてグループIDを取得してください
LINE_GROUP_ID=Cxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
